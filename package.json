{
  "name": "claude-code-skills-hub",
  "version": "0.1.0",
  "private": true,
  "description": "A bilingual Claude Code skills browser, batch installer, and ccswitch ZIP exporter.",
  "license": "AGPL-3.0-only",
  "keywords": [
    "claude-code",
    "claude-skills",
    "skills",
    "ccswitch",
    "composio",
    "vite"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "sync": "node scripts/sync-skills.mjs",
    "sync:build": "npm run sync && npm run build",
    "discover": "node scripts/discover-skill-sources.mjs",
    "discover:promote": "node scripts/discover-skill-sources.mjs --promote",
    "admin": "node scripts/review-server.mjs"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
